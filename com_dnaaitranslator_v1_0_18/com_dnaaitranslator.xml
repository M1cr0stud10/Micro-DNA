<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>COM_DNAAITRANSLATOR</name>
    <author>DNA / Microstudio</author>
    <creationDate>2026-06-12</creationDate>
    <copyright>(C) 2026 DNA / Microstudio</copyright>
    <license>GNU General Public License version 2 or later</license>
    <authorEmail></authorEmail>
    <authorUrl>https://www.divingnordadriatico.com</authorUrl>
    <version>1.0.18</version>
    <description>COM_DNAAITRANSLATOR_XML_DESCRIPTION</description>
    <element>com_dnaaitranslator</element>

    <namespace path="src">Dna\Component\DnaAiTranslator</namespace>

    <scriptfile>script.php</scriptfile>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <files folder="components/com_dnaaitranslator">
        <filename>index.html</filename>
    </files>

    <media folder="media/com_dnaaitranslator" destination="com_dnaaitranslator">
        <folder>css</folder>
        <filename>joomla.asset.json</filename>
    </media>

    <administration>
        <menu link="index.php?option=com_dnaaitranslator">COM_DNAAITRANSLATOR_MENU</menu>
        <files folder="administrator/components/com_dnaaitranslator">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <filename>index.html</filename>
            <folder>services</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
            <folder>sql</folder>
        </files>
        <languages folder="administrator/components/com_dnaaitranslator/language">
            <language tag="en-GB">en-GB/com_dnaaitranslator.ini</language>
            <language tag="en-GB">en-GB/com_dnaaitranslator.sys.ini</language>
            <language tag="it-IT">it-IT/com_dnaaitranslator.ini</language>
            <language tag="it-IT">it-IT/com_dnaaitranslator.sys.ini</language>
        </languages>
    </administration>
</extension>
